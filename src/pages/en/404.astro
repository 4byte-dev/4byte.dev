---
import DocsLayout from '../../layouts/DocsLayout.astro'
import { t } from '../../i18n/index.ts'

const lang = 'en'
const labels = await import(`../../data/${lang}/labels.json`).then((m) => m.default)
---

<DocsLayout title={t(labels, '404.title')} description={t(labels, '404.description')} noindex={true} lang={lang}>
	<div class="px-8 py-12 max-w-4xl mx-auto text-center">
		<div class="mb-6">
			<span class="text-7xl font-bold text-primary/20 dark:text-primary-dark/20 font-mono">404</span>
		</div>
		<h1 class="text-2xl font-bold text-foreground dark:text-foreground-dark mb-2">{t(labels, '404.title')}</h1>
		<p class="text-muted-foreground dark:text-muted-dark-foreground mb-6">
			{t(labels, '404.description')}
		</p>
		<div class="flex items-center justify-center gap-4 mb-8">
			<a
				href="/en/"
				class="px-4 py-2 bg-primary dark:bg-primary-dark text-background dark:text-background-dark text-sm font-medium rounded-lg hover:opacity-90 transition-opacity"
			>
				{t(labels, '404.backHome')}
			</a>
			<a
				href="/en/articles"
				class="px-4 py-2 border border-border dark:border-border-dark text-foreground dark:text-foreground-dark text-sm font-medium rounded-lg hover:bg-muted dark:hover:bg-muted-dark transition-colors"
			>
				{t(labels, '404.browseArticles')}
			</a>
		</div>
		<p class="text-xs text-muted-foreground dark:text-muted-dark-foreground">
			{t(labels, '404.contact')}
		</p>
	</div>
</DocsLayout>

<script>
	declare global {
		interface Window {
			gtag?: (...args: unknown[]) => void
			_paq?: unknown[][]
		}
	}

	if (typeof window.gtag === 'function') {
		window.gtag('event', 'page_view', {
			page_title: '404: Page Not Found',
			page_location: window.location.href,
			page_path: window.location.pathname,
		})
	}

	if (typeof window._paq === 'object') {
		window._paq.push(['setCustomUrl', window.location.href])
		window._paq.push(['setDocumentTitle', '404 — Page Not Found'])
		window._paq.push(['trackPageView'])
	}
</script>
