---
import DocsLayout from '../../layouts/DocsLayout.astro'
import { getCollection } from 'astro:content'
import categoriesTr from '../../data/tr/categories.json'
import categoriesEn from '../../data/en/categories.json'
import { getLangFromUrl, t } from '../../i18n/index.ts'
import type { Category } from '../../content.config'

const lang = getLangFromUrl(Astro.url)
const labels = await import(`../../data/${lang}/labels.json`).then((m) => m.default)

export async function getStaticPaths() {
	const allArticles = await getCollection('articles')
	const paths = []

	for (const currentLang of ['tr', 'en']) {
		const langCategories: Category[] = currentLang === 'en' ? categoriesEn : categoriesTr
		for (const cat of langCategories) {
			paths.push({
				params: { slug: cat.slug },
				props: { category: cat, lang: currentLang },
			})
		}
	}

	return paths
}

const { category, lang: catLang } = Astro.props
const langPrefix = catLang === 'en' ? '/en' : ''

const allArticles = await getCollection('articles')
const catArticles = allArticles.filter(
	(a) => a.data.lang === catLang && a.data.category === category.slug && a.data.status === 'Published',
)
---

<DocsLayout title={category.name} description={category.description} image="/og/index.png" lang={catLang}>
	<div class="px-8 py-12 max-w-5xl mx-auto">
		<a
			href={`${langPrefix}/categories`}
			class="text-sm text-primary dark:text-primary-dark hover:underline flex items-center gap-1 mb-6"
		>
			<span class="i-lucide-arrow-left w-3 h-3"></span>
			{t(labels, 'categories.allCategories')}
		</a>
		<h1 class="text-3xl font-bold tracking-tight text-foreground dark:text-foreground-dark mb-2">
			{category.name}
		</h1>
		<p class="text-muted-foreground dark:text-muted-dark-foreground mb-8">{category.description}</p>

		<div class="bg-background dark:bg-background-dark rounded-lg shadow-flat-sm overflow-hidden">
			{
				catArticles.length === 0 ? (
					<div class="px-5 py-8 text-center text-sm text-muted-foreground dark:text-muted-dark-foreground">
						{t(labels, 'categories.noArticles')}
					</div>
				) : (
					catArticles.map((article) => (
						<a
							href={`${langPrefix}/articles/${article.data.slug}`}
							class="flex items-center justify-between px-5 py-4 hover:bg-muted/30 dark:hover:bg-muted-dark/30 transition-colors border-b border-border/50 dark:border-border-dark/50 last:border-0"
						>
							<div class="min-w-0 flex-1">
								<h3 class="font-medium text-foreground dark:text-foreground-dark text-sm mb-1">
									{article.data.title}
								</h3>
								<p class="text-xs text-muted-foreground dark:text-muted-dark-foreground line-clamp-1">
									{article.data.excerpt}
								</p>
							</div>
							<div class="flex items-center gap-4 ml-4 text-xs text-muted-foreground dark:text-muted-dark-foreground shrink-0">
								<span class="flex items-center gap-1 tabular-nums">
									<span class="i-lucide-eye w-3 h-3" />
									{article.data.views.toLocaleString()}
								</span>
								<span class="i-lucide-arrow-right w-3.5 h-3.5" />
							</div>
						</a>
					))
				)
			}
		</div>
	</div>
</DocsLayout>
