---
import DocsLayout from '../../layouts/DocsLayout.astro'
import categoriesTr from '../../data/tr/categories.json'
import categoriesEn from '../../data/en/categories.json'
import { getLangFromUrl, t } from '../../i18n/index.ts'
import type { Category } from '../../content.config'

const lang = getLangFromUrl(Astro.url)
const categories: Category[] = lang === 'en' ? categoriesEn : categoriesTr
const labels = await import(`../../data/${lang}/labels.json`).then((m) => m.default)
---

<DocsLayout
	title={t(labels, 'categories.title')}
	description={t(labels, 'categories.description')}
	image="/og/index.png"
	lang={lang}
>
	<div class="px-8 py-12 max-w-5xl mx-auto">
		<h1 class="text-3xl font-bold tracking-tight text-foreground dark:text-foreground-dark mb-2">
			{t(labels, 'categories.title')}
		</h1>
		<p class="text-muted-foreground dark:text-muted-dark-foreground mb-8">{t(labels, 'categories.description')}</p>
		<div class="grid gap-4 md:grid-cols-2">
			{
				categories.map((cat) => (
					<a
						href={`${lang === 'en' ? '/en' : ''}/categories/${cat.slug}`}
						class="block p-5 bg-background dark:bg-background-dark rounded-lg shadow-flat-sm hover:shadow-flat-md transition-shadow"
					>
						<div class="flex items-center justify-between mb-2">
							<h3 class="font-semibold text-foreground dark:text-foreground-dark">{cat.name}</h3>
							<span class="text-xs tabular-nums text-muted-foreground dark:text-muted-dark-foreground bg-muted dark:bg-muted-dark px-2 py-0.5 rounded-sm">
								{cat.articleCount} {t(labels, 'categories.articlesCount')}
							</span>
						</div>
						<p class="text-sm text-muted-foreground dark:text-muted-dark-foreground mb-3">
							{cat.description}
						</p>
						<span class="text-sm text-primary dark:text-primary-dark font-medium flex items-center gap-1">
							{t(labels, 'categories.browse')} <span class="i-lucide-arrow-right w-3 h-3" />
						</span>
					</a>
				))
			}
		</div>
	</div>
</DocsLayout>
