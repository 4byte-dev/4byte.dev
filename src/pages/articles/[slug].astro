---
import DocsLayout from '../../layouts/DocsLayout.astro'
import ShareButtons from '../../components/ShareButtons.astro'
import { getCollection, render } from 'astro:content'
import { SITE } from '../../config.mjs'
import { getLangFromUrl, t } from '../../i18n/index.ts'

const lang = getLangFromUrl(Astro.url)
const labels = await import(`../../data/${lang}/labels.json`).then((m) => m.default)

export async function getStaticPaths() {
	const allArticles = await getCollection('articles')
	return allArticles.map((article) => ({
		params: { slug: article.data.slug },
		props: { article },
	}))
}

const { article } = Astro.props

if (!article || article.data.status !== 'Published') {
	return Astro.redirect('/404')
}

const { Content, headings } = await render(article)

const categorySlug = article.data.category.toLowerCase().replace(/\s+/g, '-')
const langPrefix = article.data.lang === 'en' ? '/en' : ''
const articleUrl = `${SITE.origin}${langPrefix}/articles/${article.data.slug}`
const ogImageUrl = `/og/${article.data.slug}.png`

const publishedDate = new Date(article.data.date)
const isoDate = publishedDate.toISOString()

const sections = headings.filter((h) => h.depth === 2).map((h) => h.text)

const jsonLdArticle = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: article.data.title,
	description: article.data.excerpt,
	image: `${SITE.origin}${ogImageUrl}`,
	url: articleUrl,
	datePublished: isoDate,
	dateModified: isoDate,
	author: {
		'@type': 'Person',
		name: article.data.author,
		url: SITE.origin,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE.name,
		url: SITE.origin,
	},
	inLanguage: article.data.lang,
	keywords: article.data.tags.join(', '),
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': articleUrl,
	},
}

const homeLabel = t(labels, 'article.home')
const articlesLabel = t(labels, 'nav.articles')
const byLabel = t(labels, 'article.by')
const onThisPageLabel = t(labels, 'article.onThisPage')
---

<DocsLayout
	title={article.data.title}
	description={article.data.excerpt}
	image={ogImageUrl}
	type="article"
	article={{
		publishedTime: isoDate,
		author: article.data.author,
		tags: article.data.tags,
	}}
	lang={article.data.lang}
>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />

	<div class="flex">
		<div class="flex-1 px-8 py-12 max-w-4xl mx-auto min-w-0">
			<nav
				aria-label="Breadcrumb"
				class="flex items-center gap-2 text-xs text-muted-foreground dark:text-muted-dark-foreground mb-6"
			>
				<a
					href={langPrefix ? `${langPrefix}/` : '/'}
					class="hover:text-foreground dark:hover:text-foreground-dark transition-colors">{homeLabel}</a
				>
				<span>/</span>
				<a
					href={`${langPrefix}/articles`}
					class="hover:text-foreground dark:hover:text-foreground-dark transition-colors">{articlesLabel}</a
				>
				<span>/</span>
				<a
					href={`${langPrefix}/categories/${categorySlug}`}
					class="hover:text-foreground dark:hover:text-foreground-dark transition-colors"
				>
					{article.data.category}
				</a>
				<span>/</span>
				<span class="text-foreground dark:text-foreground-dark truncate max-w-[200px]"
					>{article.data.title}</span
				>
			</nav>

			<header class="mb-8">
				<div class="flex items-center gap-2 text-sm text-primary dark:text-primary-dark font-medium mb-2">
					<a href={`${langPrefix}/categories/${categorySlug}`} class="hover:underline">
						{article.data.category}
					</a>
				</div>
				<h1 class="text-3xl font-bold tracking-tight text-foreground dark:text-foreground-dark mb-4">
					{article.data.title}
				</h1>
				<div class="flex items-center gap-4 text-sm text-muted-foreground dark:text-muted-dark-foreground mb-4">
					<span>{byLabel} {article.data.author}</span>
					<span>{article.data.date}</span>
					<span class="flex items-center gap-1"
						><span class="i-lucide-eye w-3.5 h-3.5"></span>{article.data.views.toLocaleString()}</span
					>
				</div>
				<div class="flex gap-2 flex-wrap">
					{
						article.data.tags.map((tag) => (
							<a
								href={`${langPrefix}/tags/${tag}`}
								class="px-2 py-1 bg-muted dark:bg-muted-dark text-muted-foreground dark:text-muted-dark-foreground text-xs rounded-sm hover:text-foreground dark:hover:text-foreground-dark transition-colors font-mono"
							>
								#{tag}
							</a>
						))
					}
				</div>
			</header>

			<article class="mb-12 prose dark:prose-invert max-w-none">
				<Content />
			</article>

			<ShareButtons title={article.data.title} url={articleUrl} labels={labels} />
		</div>

		<aside class="w-56 shrink-0 py-12 pr-8 hidden xl:block">
			<div class="sticky top-20">
				<h4
					class="text-[10px] font-bold uppercase tracking-[0.15em] text-muted-foreground dark:text-muted-dark-foreground mb-4"
				>
					{onThisPageLabel}
				</h4>
				<ul class="space-y-2.5 text-sm text-muted-foreground dark:text-muted-dark-foreground">
					{
						sections.map((s) => (
							<li>
								<a
									href={`#${s.toLowerCase().replace(/\s+/g, '-')}`}
									class="hover:text-foreground dark:hover:text-foreground-dark transition-colors"
								>
									{s}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</aside>
	</div>
</DocsLayout>
