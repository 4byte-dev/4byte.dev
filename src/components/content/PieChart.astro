---
import type { DataPoint } from '../../utils/chartUtils'

interface Props {
	data?: DataPoint[]
	id?: string
	height?: number
	colors?: string[]
	animated?: boolean
	donut?: boolean
	donutRatio?: number
	showLabels?: boolean
	showPercentages?: boolean
	title?: string
}

const {
	data = [],
	id = '',
	height = 300,
	colors = ['#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#14b8a6', '#f97316'],
	animated = true,
	donut = false,
	donutRatio = 0.55,
	showLabels = true,
	showPercentages = true,
	title = '',
} = Astro.props

const uniqueId = `pie-chart-${id || Math.random().toString(36).slice(2, 9)}`
const chartData = JSON.stringify(data)
const chartColors = JSON.stringify(colors)
---

<div
	class="chart-wrapper"
	data-chart-id={uniqueId}
	data-chart-data={chartData}
	data-chart-colors={chartColors}
	data-chart-animated={animated}
	data-chart-donut={donut}
	data-chart-donut-ratio={donutRatio}
	data-chart-show-labels={showLabels}
	data-chart-show-percentages={showPercentages}
	data-chart-title={title}
	data-chart-height={height}
>
	<div id={uniqueId} style={`min-height: ${height}px; width: 100%;`}></div>
</div>

<script>
	import * as d3 from 'd3'
	import { getThemeColors, getColor, createTooltip, showTooltip, hideTooltip } from '../../utils/chartUtils'
	import { onHydration } from '../../utils/hydration'

	function initPieCharts() {
		const wrappers = document.querySelectorAll('.chart-wrapper[data-chart-id^="pie-chart"]')

		wrappers.forEach((wrapper) => {
			const container = wrapper.querySelector('div') as HTMLElement
			if (!container) return

			const rawData = (wrapper as HTMLElement).dataset.chartData
			const chartData: Array<{ x: number; y: number; label?: string; color?: string }> = rawData
				? JSON.parse(rawData)
				: []
			const colors: string[] = JSON.parse((wrapper as HTMLElement).dataset.chartColors || '[]')
			const animated = (wrapper as HTMLElement).dataset.chartAnimated !== 'false'
			const donut = (wrapper as HTMLElement).dataset.chartDonut === 'true'
			const donutRatio = parseFloat((wrapper as HTMLElement).dataset.chartDonutRatio || '0.55')
			const showLabels = (wrapper as HTMLElement).dataset.chartShowLabels !== 'false'
			const showPercentages = (wrapper as HTMLElement).dataset.chartShowPercentages !== 'false'
			const chartTitle = (wrapper as HTMLElement).dataset.chartTitle || ''
			const chartHeight = parseInt((wrapper as HTMLElement).dataset.chartHeight || '300')

			if (!chartData.length) return

			const total = chartData.reduce((sum, d) => sum + d.y, 0)
			const tooltip = createTooltip(container)

			function initChart() {
				container.innerHTML = ''
				const width = container.clientWidth
				const h = chartHeight
				const radius = Math.min(width, h) / 2 - 20

				if (chartTitle) {
					const titleEl = document.createElement('div')
					titleEl.className = 'chart-title'
					titleEl.textContent = chartTitle
					titleEl.style.cssText = `
					font-size: 16px;
					font-weight: 600;
					text-align: center;
					color: ${getThemeColors().textColor};
				`
					container.appendChild(titleEl)
				}

				const svg = d3
					.select(container)
					.append('svg')
					.attr('width', width)
					.attr('height', h)
					.attr('viewBox', `0 0 ${width} ${h}`)
					.attr('preserveAspectRatio', 'xMidYMid meet')

				const { textColor } = getThemeColors()

				const g = svg.append('g').attr('transform', `translate(${width / 2},${h / 2})`)

				const innerRadius = donut ? radius * donutRatio : 0

				const pie = d3
					.pie<{ x: number; y: number; label?: string; color?: string }>()
					.value((d) => d.y)
					.sort(null)
					.padAngle(0.02)

				const arc = d3
					.arc<d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>>()
					.innerRadius(innerRadius)
					.outerRadius(radius)

				const arcHover = d3
					.arc<d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>>()
					.innerRadius(innerRadius)
					.outerRadius(radius + 12)

				const arcLabel = d3
					.arc<d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>>()
					.innerRadius(radius * 0.8)
					.outerRadius(radius * 0.8)

				const arcs = g.selectAll('.arc').data(pie(chartData)).enter().append('g').attr('class', 'arc')

				const paths = arcs
					.append('path')
					.attr('fill', (d, i) => d.data.color || getColor(i, colors))
					.attr('stroke', '#fff')
					.attr('stroke-width', 2)
					.style('cursor', 'pointer')
					.style('transition', 'filter 0.2s ease')

				if (animated) {
					paths
						.attr(
							'd',
							d3
								.arc<d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>>()
								.innerRadius(innerRadius)
								.outerRadius(innerRadius),
						)
						.transition()
						.duration(800)
						.delay((_, i) => i * 80)
						.ease(d3.easeCubicOut)
						.attrTween('d', function (d) {
							const interpolate = d3.interpolate({ startAngle: d.startAngle, endAngle: d.startAngle }, d)
							return (t) => arc(interpolate(t))!
						})
				}

				paths.on('mousemove', function (event, d) {
					d3.select(this)
						.transition()
						.duration(200)
						.attr('d', arcHover(d)!)
						.style('filter', `drop-shadow(0 4px 12px rgba(0,0,0,0.25))`)

					const percentage = ((d.data.y / total) * 100).toFixed(1)
					const display = showPercentages
						? `<strong>${d.data.label}</strong><br/>Value: ${d.data.y.toLocaleString()}<br/>${percentage}%`
						: `<strong>${d.data.label}</strong><br/>Value: ${d.data.y.toLocaleString()}`

					showTooltip(tooltip, event.offsetX, event.offsetY, display, container.getBoundingClientRect())
				})

				paths.on('mouseleave', function (this: SVGPathElement) {
					const datum = d3
						.select<
							SVGPathElement,
							d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>
						>(this)
						.datum()
					d3.select(this).transition().duration(200).attr('d', arc(datum)!).style('filter', 'none')

					hideTooltip(tooltip)
				})

				paths.on('click', function (this: SVGPathElement, _, d) {
					g.selectAll<
						SVGPathElement,
						d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>
					>('path')
						.transition()
						.duration(300)
						.attr('opacity', (p) => (p === d ? 1 : 0.3))

					d3.select(this)
						.transition()
						.duration(300)
						.attr('d', arcHover(d)!)
						.style('filter', `drop-shadow(0 4px 12px rgba(0,0,0,0.25))`)

					const customEvent = new CustomEvent('chart:click', {
						bubbles: true,
						detail: { type: 'pie', x: d.data.x, y: d.data.y, label: d.data.label },
					})
					container.dispatchEvent(customEvent)
				})

				container.addEventListener('chart:reset', () => {
					g.selectAll<
						SVGPathElement,
						d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>
					>('path')
						.transition()
						.duration(300)
						.attr('opacity', 1)
						.attr('d', (d) => arc(d)!)
						.style('filter', 'none')
				})

				if (showLabels && !donut) {
					const labelThreshold = 0.05
					arcs.filter((d) => d.endAngle - d.startAngle > labelThreshold * 2 * Math.PI)
						.append('text')
						.attr('transform', (d) => `translate(${arcLabel.centroid(d)})`)
						.attr('text-anchor', 'middle')
						.attr('fill', textColor)
						.attr('font-size', '11px')
						.attr('font-weight', '600')
						.attr('font-family', 'inherit')
						.style('pointer-events', 'none')
						.text((d) => {
							const pct = (d.data.y / total) * 100
							return pct >= 5 ? `${pct.toFixed(0)}%` : ''
						})
						.attr('opacity', 0)
						.transition()
						.duration(400)
						.delay((_, i) => 800 + i * 80)
						.attr('opacity', 1)
				}

				if (donut) {
					const centerText = g.append('g').attr('class', 'center-text')
					const totalValue = centerText
						.append('text')
						.attr('text-anchor', 'middle')
						.attr('dy', '-0.1em')
						.attr('fill', textColor)
						.attr('font-size', radius * 0.2)
						.attr('font-weight', '700')
						.attr('font-family', 'inherit')
						.text(total.toLocaleString())

					const totalLabel = centerText
						.append('text')
						.attr('text-anchor', 'middle')
						.attr('dy', '1.5em')
						.attr('fill', textColor)
						.attr('font-size', radius * 0.1)
						.attr('font-weight', '500')
						.attr('font-family', 'inherit')
						.style('opacity', 0.7)
						.text('Total')

					if (animated) {
						totalValue.attr('opacity', 0).transition().delay(600).duration(400).attr('opacity', 1)
						totalLabel.attr('opacity', 0).transition().delay(700).duration(400).attr('opacity', 0.7)
					}
				}

				const legend = svg
					.append('g')
					.attr('transform', `translate(${width - 100}, 10)`)
					.attr('class', 'legend')

				const legendItems = legend
					.selectAll('.legend-item')
					.data(chartData)
					.enter()
					.append('g')
					.attr('transform', (_, i) => `translate(0, ${i * 22})`)
					.style('cursor', 'pointer')

				legendItems
					.append('rect')
					.attr('width', 12)
					.attr('height', 12)
					.attr('rx', 3)
					.attr('fill', (d, i) => d.color || getColor(i, colors))

				legendItems
					.append('text')
					.attr('x', 18)
					.attr('y', 10)
					.attr('fill', textColor)
					.attr('font-size', '11px')
					.attr('font-weight', '500')
					.attr('font-family', 'inherit')
					.text((d) => {
						const label = d.label || String(d.x)
						return label.length > 10 ? label.slice(0, 10) + '…' : label
					})

				legendItems.on('mousemove', function (_, d) {
					g.selectAll<
						SVGPathElement,
						d3.PieArcDatum<{ x: number; y: number; label?: string; color?: string }>
					>('path')
						.transition()
						.duration(200)
						.attr('opacity', (p) =>
							(p.data.label || String(p.data.x)) === (d.label || String(d.x)) ? 1 : 0.3,
						)
				})

				legendItems.on('mouseleave', function () {
					g.selectAll('path').transition().duration(200).attr('opacity', 1)
				})

				if (animated) {
					legendItems
						.attr('opacity', 0)
						.transition()
						.duration(400)
						.delay((_, i) => 600 + i * 60)
						.attr('opacity', 1)
				}
			}

			const observer = new ResizeObserver(() => initChart())
			observer.observe(container)
			initChart()
		})
	}

	onHydration(initPieCharts)
</script>
