---
import type { DataPoint } from '../../utils/chartUtils'

interface AxisConfig {
	min?: number
	max?: number
	tickInterval?: number
}

interface Props {
	data?: DataPoint[]
	id?: string
	height?: number
	colors?: string[]
	animated?: boolean
	showTrendline?: boolean
	trendlineColor?: string
	showLabels?: boolean
	pointSize?: number
	pointOpacity?: number
	showGrid?: boolean
	xAxis?: AxisConfig
	yAxis?: AxisConfig
	title?: string
}

const {
	data = [],
	id = '',
	height = 300,
	colors = ['#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#14b8a6', '#f97316'],
	animated = true,
	showTrendline = false,
	trendlineColor = '#ef4444',
	showLabels = true,
	pointSize = 6,
	pointOpacity = 1,
	showGrid = true,
	xAxis = {},
	yAxis = {},
	title = '',
} = Astro.props

const chartId = `scatter-chart-${id || Math.random().toString(36).slice(2, 9)}`
const chartData = JSON.stringify(data)
const chartColors = JSON.stringify(colors)
---

<div
	class="chart-wrapper"
	data-chart-id={chartId}
	data-chart-data={chartData}
	data-chart-colors={chartColors}
	data-chart-animated={animated}
	data-chart-show-trendline={showTrendline}
	data-chart-trendline-color={trendlineColor}
	data-chart-show-labels={showLabels}
	data-chart-point-size={pointSize}
	data-chart-point-opacity={pointOpacity}
	data-chart-show-grid={showGrid}
	data-chart-x-axis={JSON.stringify(xAxis)}
	data-chart-y-axis={JSON.stringify(yAxis)}
	data-chart-title={title}
	data-chart-height={height}
>
	<div id={chartId} style={`min-height: ${height}px; width: 100%;`}></div>
	<div class="chart-controls" style="display: flex; gap: 8px; margin-top: 8px; justify-content: flex-end;">
		<button
			class="chart-btn zoom-in"
			title="Zoom In"
			style="background: oklch(0.9 0 0); border: 1px solid oklch(0.85 0 0); border-radius: 4px; padding: 4px 8px; cursor: pointer; font-size: 12px; color: oklch(0.2 0 0);"
		>
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
				><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg
			>
		</button>
		<button
			class="chart-btn zoom-out"
			title="Zoom Out"
			style="background: oklch(0.9 0 0); border: 1px solid oklch(0.85 0 0); border-radius: 4px; padding: 4px 8px; cursor: pointer; font-size: 12px; color: oklch(0.2 0 0);"
		>
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
				><line x1="5" y1="12" x2="19" y2="12"></line></svg
			>
		</button>
		<button
			class="chart-btn reset"
			title="Reset"
			style="background: oklch(0.9 0 0); border: 1px solid oklch(0.85 0 0); border-radius: 4px; padding: 4px 8px; cursor: pointer; font-size: 12px; color: oklch(0.2 0 0);"
		>
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
				><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg
			>
		</button>
	</div>
</div>

<script>
	import * as d3 from 'd3'
	import { getThemeColors, getColor, createTooltip, showTooltip, hideTooltip } from '../../utils/chartUtils'

	const wrappers = document.querySelectorAll('.chart-wrapper[data-chart-id^="scatter-chart"]')

	wrappers.forEach((wrapper) => {
		const container = wrapper.querySelector('div') as HTMLElement
		if (!container) return

		const rawData = (wrapper as HTMLElement).dataset.chartData
		const chartData: Array<{ x: number; y: number; color?: string; label?: string }> = rawData
			? JSON.parse(rawData)
			: []
		const colors: string[] = JSON.parse((wrapper as HTMLElement).dataset.chartColors || '[]')
		const animated = (wrapper as HTMLElement).dataset.chartAnimated !== 'false'
		const showTrendline = (wrapper as HTMLElement).dataset.chartShowTrendline === 'true'
		const trendlineColor = (wrapper as HTMLElement).dataset.chartTrendlineColor || '#ef4444'
		const showLabels = (wrapper as HTMLElement).dataset.chartShowLabels !== 'false'
		const pointSize = parseFloat((wrapper as HTMLElement).dataset.chartPointSize || '6')
		const pointOpacity = parseFloat((wrapper as HTMLElement).dataset.chartPointOpacity || '1')
		const showGrid = (wrapper as HTMLElement).dataset.chartShowGrid !== 'false'
		const xAxisConfig = JSON.parse((wrapper as HTMLElement).dataset.chartXAxis || '{}')
		const yAxisConfig = JSON.parse((wrapper as HTMLElement).dataset.chartYAxis || '{}')
		const chartTitle = (wrapper as HTMLElement).dataset.chartTitle || ''
		const chartHeight = parseInt((wrapper as HTMLElement).dataset.chartHeight || '300')
		const chartId = parseInt((wrapper as HTMLElement).dataset.chartId || 'uid')

		if (!chartData.length) return

		const margin = { top: 20, right: 20, bottom: 40, left: 60 }
		const tooltip = createTooltip(container)

		function applyAxisStyles(axisG: d3.Selection<SVGGElement, unknown, null, undefined>, textColor: string) {
			const { axisColor } = getThemeColors()
			axisG.select('.domain').style('stroke', axisColor).style('stroke-width', 1.5)
			axisG.selectAll('.tick line').style('stroke', axisColor).style('stroke-width', 1)
			axisG
				.selectAll('.tick text')
				.attr('fill', textColor)
				.style('fill', textColor)
				.attr('font-size', '12px')
				.attr('font-family', 'inherit')
				.style('font-weight', '500')
		}

		function renderGrid(
			g: d3.Selection<SVGGElement, unknown, null, undefined>,
			y: d3.ScaleLinear<number, number>,
			w: number,
			gridColor: string,
		) {
			const gridG = g.append('g').attr('class', 'grid')
			gridG.call(
				d3
					.axisLeft(y)
					.tickSize(-w)
					.tickFormat(() => ''),
			)
			gridG.selectAll('line').style('stroke', gridColor).style('stroke-dasharray', '3,3').style('stroke-width', 1)
			gridG.select('.domain').remove()
			return gridG
		}

		function calculateTrendline(
			data: Array<{ x: number; y: number }>,
			x: d3.ScaleLinear<number, number>,
			y: d3.ScaleLinear<number, number>,
		) {
			const n = data.length
			if (n < 2) return null

			const xValues = data.map((d) => d.x)
			const yValues = data.map((d) => d.y)

			const xMean = xValues.reduce((a, b) => a + b, 0) / n
			const yMean = yValues.reduce((a, b) => a + b, 0) / n

			let numerator = 0
			let denominator = 0
			for (let i = 0; i < n; i++) {
				numerator += (xValues[i] - xMean) * (yValues[i] - yMean)
				denominator += (xValues[i] - xMean) ** 2
			}

			const slope = denominator !== 0 ? numerator / denominator : 0
			const intercept = yMean - slope * xMean

			const xMin = d3.min(xValues)!
			const xMax = d3.max(xValues)!
			const yStart = slope * xMin + intercept
			const yEnd = slope * xMax + intercept

			return {
				x1: x(xMin),
				y1: y(yStart),
				x2: x(xMax),
				y2: y(yEnd),
				slope,
				r2:
					denominator !== 0
						? numerator ** 2 / (denominator * yValues.reduce((s, v) => s + (v - yMean) ** 2, 0))
						: 0,
			}
		}

		function initChart() {
			container.innerHTML = ''
			const width = container.clientWidth
			const h = chartHeight
			const innerWidth = width - margin.left - margin.right
			const innerHeight = h - margin.top - margin.bottom

			if (chartTitle) {
				const titleEl = document.createElement('div')
				titleEl.className = 'chart-title'
				titleEl.textContent = chartTitle
				titleEl.style.cssText = `
					font-size: 16px;
					font-weight: 600;
					text-align: center;
					color: ${getThemeColors().textColor};
				`
				container.appendChild(titleEl)
			}

			const svg = d3
				.select(container)
				.append('svg')
				.attr('width', width)
				.attr('height', h)
				.attr('viewBox', `0 0 ${width} ${h}`)
				.attr('preserveAspectRatio', 'xMidYMid meet')
				.style('overflow', 'hidden')
				.style('cursor', 'grab')

			const defs = svg.append('defs')
			const clipId = `clip-${chartId}`
			defs.append('clipPath')
				.attr('id', clipId)
				.append('rect')
				.attr('width', innerWidth)
				.attr('height', innerHeight)
			const glowFilter = defs.append('filter').attr('id', `scatter-glow-${chartId}`)
			glowFilter.append('feGaussianBlur').attr('stdDeviation', 2).attr('result', 'coloredBlur')
			const feMerge = glowFilter.append('feMerge')
			feMerge.append('feMergeNode').attr('in', 'coloredBlur')
			feMerge.append('feMergeNode').attr('in', 'SourceGraphic')

			const g = svg
				.append('g')
				.attr('class', 'chart-group')
				.attr('transform', `translate(${margin.left},${margin.top})`)
			const chartContent = g.append('g').attr('clip-path', `url(#${clipId})`)
			const { textColor, gridColor } = getThemeColors()

			const xMin = xAxisConfig.min ?? (chartData.length > 0 ? d3.min(chartData, (d) => d.x)! : 0)
			const xMax =
				xAxisConfig.max ?? (chartData.length > 0 ? d3.max(chartData, (d) => d.x)! : chartData.length + 1)
			const yMin = yAxisConfig.min ?? 0
			const yMax = yAxisConfig.max ?? d3.max(chartData, (d) => d.y)! * 1.15

			const x = d3.scaleLinear().domain([xMin, xMax]).range([0, innerWidth])

			const y = d3.scaleLinear().domain([yMin, yMax]).range([innerHeight, 0]).nice()

			if (showGrid) {
				renderGrid(g, y, innerWidth, gridColor)
			}

			const xAxisG = g.append('g').attr('class', 'x-axis').attr('transform', `translate(0,${innerHeight})`)
			if (xAxisConfig.tickInterval) {
				const tickCount = Math.ceil((xMax - xMin) / xAxisConfig.tickInterval)
				xAxisG.call(d3.axisBottom(x).ticks(tickCount))
			} else {
				xAxisG.call(d3.axisBottom(x))
			}
			applyAxisStyles(xAxisG, textColor)

			const yAxisG = g.append('g').attr('class', 'y-axis')
			yAxisG.call(d3.axisLeft(y).ticks(Math.min(chartData.length, 10)))
			applyAxisStyles(yAxisG, textColor)

			if (showTrendline) {
				const trend = calculateTrendline(chartData, x, y)
				if (trend) {
					const trendline = chartContent
						.append('line')
						.attr('class', 'trendline')
						.attr('x1', trend.x1)
						.attr('y1', trend.y1)
						.attr('x2', trend.x2)
						.attr('y2', trend.y2)
						.attr('stroke', trendlineColor)
						.attr('stroke-width', 2)
						.attr('stroke-dasharray', '6,4')
						.attr('opacity', 0.7)

					if (animated) {
						trendline.attr('opacity', 0).transition().delay(600).duration(500).attr('opacity', 0.7)
					}

					const r2 = isNaN(trend.r2) ? 0 : Math.max(0, Math.min(1, trend.r2))
					const legendText = g
						.append('text')
						.attr('x', innerWidth - 5)
						.attr('y', 15)
						.attr('text-anchor', 'end')
						.attr('fill', trendlineColor)
						.attr('font-size', '11px')
						.attr('font-weight', '600')
						.attr('font-family', 'inherit')
						.text(`R² = ${r2.toFixed(3)}`)

					if (animated) {
						legendText.attr('opacity', 0).transition().delay(800).duration(400).attr('opacity', 1)
					}
				}
			}

			const dots = chartContent
				.selectAll('.dot')
				.data(chartData)
				.enter()
				.append('circle')
				.attr('class', 'dot')
				.attr('cx', (d) => x(d.x))
				.attr('cy', (d) => y(d.y))
				.attr('r', pointSize)
				.attr('fill', (d, i) => d.color || getColor(i, colors))
				.attr('stroke', '#fff')
				.attr('stroke-width', 2)
				.attr('opacity', pointOpacity)
				.style('cursor', 'pointer')
				.style('filter', `url(#scatter-glow-${chartId})`)

			if (animated) {
				dots.attr('opacity', 0)
					.attr('r', 0)
					.transition()
					.duration(500)
					.delay((_, i) => i * 60)
					.ease(d3.easeBackOut.overshoot(1.5))
					.attr('opacity', pointOpacity)
					.attr('r', pointSize)
			}

			dots.on('mousemove', function (event, d) {
				d3.select(this)
					.transition()
					.duration(150)
					.attr('r', pointSize + 4)
					.style('filter', `drop-shadow(0 0 8px ${d.color || colors[0]})`)

				const labelText = d.label ? `<strong>${d.label}</strong><br/>` : ''
				showTooltip(
					tooltip,
					event.offsetX,
					event.offsetY,
					`${labelText}x: ${d.x}<br/>y: ${d.y.toLocaleString()}`,
					container.getBoundingClientRect(),
				)
			})

			dots.on('mouseleave', function () {
				d3.select(this)
					.transition()
					.duration(150)
					.attr('r', pointSize)
					.style('filter', `url(#scatter-glow-${chartId})`)

				hideTooltip(tooltip)
			})

			dots.on('click', function (_, d) {
				const customEvent = new CustomEvent('chart:click', {
					bubbles: true,
					detail: { type: 'scatter', x: d.x, y: d.y, label: d.label },
				})
				container.dispatchEvent(customEvent)
			})

			if (showLabels) {
				const labels = chartContent
					.selectAll('.label')
					.data(chartData)
					.enter()
					.append('text')
					.attr('class', 'label')
					.attr('x', (d) => x(d.x))
					.attr('y', (d) => y(d.y))
					.attr('dx', pointSize + 6)
					.attr('dy', 4)
					.attr('fill', textColor)
					.attr('font-size', '11px')
					.attr('font-weight', '500')
					.attr('font-family', 'inherit')
					.style('pointer-events', 'none')
					.text((d) => d.label || `(${d.x}, ${d.y})`)

				if (animated) {
					labels
						.attr('opacity', 0)
						.transition()
						.duration(400)
						.delay((_, i) => 500 + i * 60)
						.attr('opacity', 1)
				}
			}

			const zoom = d3
				.zoom<SVGSVGElement, unknown>()
				.scaleExtent([0.5, 10])
				.translateExtent([
					[-innerWidth, -innerHeight],
					[innerWidth * 2, innerHeight * 2],
				])
				.on('zoom', (event) => {
					const newX = event.transform.rescaleX(x)

					xAxisG.call(d3.axisBottom(newX))
					applyAxisStyles(xAxisG, textColor)

					dots.attr('cx', (d) => newX(d.x))

					if (showLabels) {
						chartContent
							.selectAll<
								SVGTextElement,
								{ x: number; y: number; label?: string; color?: string }
							>('.label')
							.attr('x', (d) => newX(d.x))
					}

					chartContent.selectAll('.trendline').remove()
					if (showTrendline) {
						const trend = calculateTrendline(chartData, newX, y)
						if (trend) {
							chartContent
								.append('line')
								.attr('class', 'trendline')
								.attr('x1', trend.x1)
								.attr('y1', trend.y1)
								.attr('x2', trend.x2)
								.attr('y2', trend.y2)
								.attr('stroke', trendlineColor)
								.attr('stroke-width', 2)
								.attr('stroke-dasharray', '6,4')
								.attr('opacity', 0.7)
						}
					}
				})

			svg.call(zoom)

			const zoomBtns = wrapper.querySelectorAll('.chart-btn')
			zoomBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					if ((btn as HTMLElement).classList.contains('zoom-in')) {
						svg.transition().duration(300).call(zoom.scaleBy, 1.5)
					} else if ((btn as HTMLElement).classList.contains('zoom-out')) {
						svg.transition().duration(300).call(zoom.scaleBy, 0.67)
					} else {
						svg.transition().duration(300).call(zoom.transform, d3.zoomIdentity)
					}
				})
			})

			dots.call(
				d3
					.drag<SVGCircleElement, { x: number; y: number; color?: string; label?: string }>()
					.on('start', function (this: SVGCircleElement) {
						d3.select(this).raise().style('cursor', 'grabbing')
					})
					.on('drag', function (this: SVGCircleElement, event) {
						d3.select(this).attr('cx', Math.max(0, Math.min(innerWidth, event.x)))
					})
					.on('end', function (this: SVGCircleElement) {
						d3.select(this).style('cursor', 'pointer')
					}),
			)
		}

		const observer = new ResizeObserver(() => initChart())
		observer.observe(container)
		initChart()
	})
</script>
