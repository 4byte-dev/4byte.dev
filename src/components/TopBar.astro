---
import LanguageSelector from './LanguageSelector.astro'
import { t } from '../i18n/index.ts'

interface Props {
	lang: string
	currentPath: string
	labels: Record<string, unknown>
}

const { lang, currentPath, labels } = Astro.props
---

<header
	class="h-14 border-b border-border/50 dark:border-border-dark/50 flex items-center justify-between px-6 bg-background dark:bg-background-dark sticky top-0 z-10"
>
	<div class="flex items-center gap-4 lg:hidden">
		<button
			id="mobile-menu-btn"
			class="text-muted-foreground dark:text-muted-dark-foreground hover:text-foreground dark:hover:text-foreground-dark"
		>
			<span class="i-lucide-menu w-5 h-5"></span>
		</button>
		<a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2">
			<div
				class="w-6 h-6 bg-primary dark:bg-primary-dark rounded flex items-center justify-center text-primary-foreground dark:text-primary-dark-foreground font-bold text-[10px]"
			>
				4
			</div>
			<span class="font-bold text-sm text-foreground dark:text-foreground-dark">4Byte.dev</span>
		</a>
	</div>

	<div class="relative flex-1 max-w-md hidden sm:block">
		<button
			data-search-trigger
			class="w-full flex items-center gap-2 pl-3 pr-4 py-2 text-sm rounded-md ring-1 ring-border dark:ring-border-dark bg-muted/30 dark:bg-muted-dark/30 hover:ring-2 hover:ring-primary/50 dark:hover:ring-primary-dark/50 transition-all text-muted-foreground dark:text-muted-dark-foreground hover:text-muted-foreground/70 dark:hover:text-muted-dark-foreground/70"
		>
			<span class="i-lucide-search w-4 h-4"></span>
			<span class="flex-1 text-left">{t(labels, 'search.placeholder')}</span>
			<kbd
				class="hidden lg:inline-flex items-center gap-0.5 rounded border border-border dark:border-border-dark bg-background dark:bg-background-dark px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground dark:text-muted-dark-foreground"
			>
				<span class="text-xs">⌘</span>K
			</kbd>
		</button>
	</div>

	<div class="flex items-center gap-2 lg:gap-3">
		<div class="hidden lg:block">
			<LanguageSelector currentLang={lang} currentPath={currentPath} labels={labels} />
		</div>
		<button
			id="mobile-theme-toggle"
			class="text-muted-foreground dark:text-muted-dark-foreground hover:text-foreground dark:hover:text-foreground-dark lg:hidden"
			title="Toggle theme"
		>
			<span class="mobile-theme-icon i-lucide-moon w-4 h-4"></span>
		</button>
		<button
			id="desktop-theme-toggle"
			class="hidden lg:flex items-center gap-1.5 px-3 py-2 text-sm text-muted-foreground dark:text-muted-dark-foreground rounded-md hover:bg-muted dark:hover:bg-muted-dark hover:text-foreground dark:hover:text-foreground-dark transition-colors"
			title="Toggle theme"
		>
			<span class="desktop-theme-icon i-lucide-moon w-4 h-4"></span>
		</button>
	</div>
</header>

<script>
	import { onHydration } from '../utils/hydration'

	function initTopBar() {
		const mobileToggle = document.getElementById('mobile-theme-toggle')
		const desktopToggle = document.getElementById('desktop-theme-toggle')
		const mobileIcon = mobileToggle?.querySelector('.mobile-theme-icon')
		const desktopIcon = desktopToggle?.querySelector('.desktop-theme-icon')

		function updateMobileTheme() {
			const isDark = document.documentElement.classList.contains('dark')
			if (mobileIcon) {
				mobileIcon.className = `mobile-theme-icon w-4 h-4 ${isDark ? 'i-lucide-sun' : 'i-lucide-moon'}`
			}
			if (desktopIcon) {
				desktopIcon.className = `desktop-theme-icon w-4 h-4 ${isDark ? 'i-lucide-sun' : 'i-lucide-moon'}`
			}
		}

		function toggleTheme() {
			document.documentElement.classList.toggle('dark')
			localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light')
			updateMobileTheme()
		}

		mobileToggle?.addEventListener('click', toggleTheme)
		desktopToggle?.addEventListener('click', toggleTheme)

		updateMobileTheme()
	}

	onHydration(initTopBar)
</script>
