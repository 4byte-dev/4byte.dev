---
import categoriesTr from '../data/tr/categories.json'
import tagsTr from '../data/tr/tags.json'
import categoriesEn from '../data/en/categories.json'
import tagsEn from '../data/en/tags.json'
import LanguageSelector from './LanguageSelector.astro'
import { t } from '../i18n/index.ts'
import type { Category, Tag } from '../content.config'

interface Props {
	lang: string
	currentPath: string
	labels: Record<string, unknown>
}

const { lang, currentPath, labels } = Astro.props

const categories: Category[] = lang === 'en' ? categoriesEn : categoriesTr
const tags: Tag[] = lang === 'en' ? tagsEn : tagsTr

const navLabels = labels.nav as Record<string, string> | undefined
const themeLabels = labels.theme as Record<string, string> | undefined

const navItems = [
	{ title: navLabels?.home || 'Home', url: lang === 'en' ? '/en/' : '/' },
	{ title: navLabels?.articles || 'Articles', url: lang === 'en' ? '/en/articles' : '/articles' },
	{ title: navLabels?.categories || 'Categories', url: lang === 'en' ? '/en/categories' : '/categories' },
	{ title: navLabels?.tags || 'Tags', url: lang === 'en' ? '/en/tags' : '/tags' },
]

function isActive(path: string): boolean {
	if (path === '/' || path === '/en/') return currentPath === path
	return currentPath.startsWith(path)
}

const topCategories = [...categories].sort((a, b) => b.articleCount - a.articleCount).slice(0, 5)
const topTags = [...tags].sort((a, b) => b.articleCount - a.articleCount).slice(0, 8)
---

<aside
	class="w-64 shrink-0 border-r border-border dark:border-border-dark bg-background dark:bg-background-dark hidden lg:flex flex-col h-screen sticky top-0"
>
	<div class="p-6 border-b border-border dark:border-border-dark">
		<a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2">
			<img src="/logo-light.png" height={32} alt="4byte logo" class="block dark:hidden" />
			<img src="/logo-dark.png" height={32} alt="4byte logo" class="hidden dark:block" />
		</a>
	</div>

	<nav class="flex-1 p-4 space-y-1 overflow-y-auto">
		<div
			class="text-[10px] font-bold tracking-[0.15em] uppercase text-muted-foreground dark:text-muted-dark-foreground mb-3 ml-3"
		>
			{t(labels, 'nav.home')}
		</div>
		{
			navItems.map((item) => (
				<a
					href={item.url}
					class={`flex items-center gap-2.5 px-3 py-2 text-sm rounded-md transition-colors ${
						isActive(item.url)
							? 'bg-primary/10 dark:bg-primary-dark/20 text-primary dark:text-primary-dark font-medium'
							: 'text-muted-foreground dark:text-muted-dark-foreground hover:bg-muted dark:hover:bg-muted-dark hover:text-foreground dark:hover:text-foreground-dark'
					}`}
				>
					{item.title === (navLabels?.home || 'Home') && <span class="i-lucide-home w-4 h-4" />}
					{item.title === (navLabels?.articles || 'Articles') && <span class="i-lucide-file-text w-4 h-4" />}
					{item.title === (navLabels?.categories || 'Categories') && <span class="i-lucide-folder w-4 h-4" />}
					{item.title === (navLabels?.tags || 'Tags') && <span class="i-lucide-tag w-4 h-4" />}
					<span>{item.title}</span>
				</a>
			))
		}

		<div
			class="text-[10px] font-bold tracking-[0.15em] uppercase text-muted-foreground dark:text-muted-dark-foreground mt-6 mb-3 ml-3"
		>
			{t(labels, 'nav.categories') || 'Categories'}
		</div>
		{
			topCategories.map((cat) => (
				<a
					href={`${lang === 'en' ? '/en' : ''}/categories/${cat.slug}`}
					class={`flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors ${
						currentPath === `${lang === 'en' ? '/en' : ''}/categories/${cat.slug}`
							? 'bg-primary/10 dark:bg-primary-dark/20 text-primary dark:text-primary-dark font-medium'
							: 'text-muted-foreground dark:text-muted-dark-foreground hover:bg-muted dark:hover:bg-muted-dark hover:text-foreground dark:hover:text-foreground-dark'
					}`}
				>
					<span>{cat.name}</span>
					<span class="text-xs tabular-nums">{cat.articleCount}</span>
				</a>
			))
		}

		<div
			class="text-[10px] font-bold tracking-[0.15em] uppercase text-muted-foreground dark:text-muted-dark-foreground mt-6 mb-3 ml-3"
		>
			{t(labels, 'nav.tags') || 'Tags'}
		</div>

		<div class="flex flex-wrap gap-2 px-3 pb-4 mt-3">
			{
				topTags.map((tag) => (
					<a
						href={`${lang === 'en' ? '/en' : ''}/tags/${tag.slug}`}
						class={`inline-flex items-center px-2 py-1 rounded-md text-xs transition-colors ${
							currentPath === `${lang === 'en' ? '/en' : ''}/tags/${tag.slug}`
								? 'bg-primary text-primary-foreground dark:bg-primary-dark dark:text-primary-dark-foreground font-medium'
								: 'bg-muted dark:bg-muted-dark text-muted-foreground dark:text-muted-dark-foreground hover:bg-primary/20 dark:hover:bg-primary-dark/20 hover:text-foreground dark:hover:text-foreground-dark'
						}`}
					>
						#{tag.name}
					</a>
				))
			}
		</div>
	</nav>

	<div class="p-4 border-t border-border dark:border-border-dark space-y-1">
		<LanguageSelector currentLang={lang} currentPath={currentPath} labels={labels} direction="up" />
		<button
			id="theme-toggle"
			data-dark-label={themeLabels?.lightMode || 'Light Mode'}
			data-light-label={themeLabels?.darkMode || 'Dark Mode'}
			class="flex items-center gap-2.5 px-3 py-2 text-sm text-muted-foreground dark:text-muted-dark-foreground rounded-md hover:bg-muted dark:hover:bg-muted-dark hover:text-foreground dark:hover:text-foreground-dark transition-colors w-full"
		>
			<span class="theme-icon i-lucide-moon w-4 h-4"></span>
			<span class="theme-text">{themeLabels?.darkMode || 'Dark Mode'}</span>
		</button>
	</div>
</aside>

<script>
	import { onHydration } from '../utils/hydration'

	function initSidebarTheme() {
		const toggle = document.getElementById('theme-toggle')
		const icon = toggle?.querySelector('.theme-icon')
		const text = toggle?.querySelector('.theme-text')

		function updateTheme() {
			const isDark = document.documentElement.classList.contains('dark')
			if (icon) {
				icon.className = `theme-icon w-4 h-4 ${isDark ? 'i-lucide-sun' : 'i-lucide-moon'}`
			}
			if (text && toggle) {
				text.textContent = isDark
					? toggle.dataset.darkLabel || 'Light Mode'
					: toggle.dataset.lightLabel || 'Dark Mode'
			}
		}

		toggle?.addEventListener('click', () => {
			document.documentElement.classList.toggle('dark')
			localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light')
			updateTheme()
		})

		updateTheme()
	}

	onHydration(initSidebarTheme)
</script>
