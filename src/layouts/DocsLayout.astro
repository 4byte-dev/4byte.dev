---
import BaseLayout from './BaseLayout.astro'
import Sidebar from '../components/Sidebar.astro'
import TopBar from '../components/TopBar.astro'

interface Props {
	title?: string
	description?: string
	image?: string
	type?: 'website' | 'article'
	article?: {
		publishedTime?: string
		modifiedTime?: string
		author?: string
		tags?: string[]
	}
	noindex?: boolean
}

const { title, description, image, type, article, noindex } = Astro.props
const year = new Date().getFullYear();
---

<BaseLayout title={title} description={description} image={image} type={type} article={article} noindex={noindex}>
	<slot name="head" slot="head" />

	<div class="flex min-h-screen bg-background dark:bg-background-dark w-full">
		<Sidebar />
		<div class="flex-1 flex flex-col min-w-0">
			<TopBar />
			<main class="flex-1">
				<slot />
			</main>
			<footer class="border-t border-border/50 dark:border-border-dark/50 py-6 px-8">
				<p class="text-xs text-muted-foreground dark:text-muted-dark-foreground text-center">
					© {year} 4Byte.dev. A machine learning documentation project.
				</p>
			</footer>
		</div>
	</div>
</BaseLayout>
